# OS junk and editor/IDE files live in the global gitignore
# (~/.gitignore_global via git config --global core.excludesfile).
# This file is only for artifacts produced by this project's stack.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.python-version

# Environments / secrets
.env
.env.*
*.local
secrets.*
*.pem

# dlt
.dlt/secrets.toml

# dbt
target/
dbt_packages/
logs/
.user.yml

# DuckDB local artifacts
*.duckdb
*.duckdb.wal

# Terraform — NB: .terraform.lock.hcl IS committed (pins provider versions)
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json

# Data / lake artifacts (local)
*.parquet
data/
tmp/

# Node / frontend
node_modules/
dist/
build/
.cache/
